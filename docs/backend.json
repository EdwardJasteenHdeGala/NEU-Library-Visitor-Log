
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Stores user profile information for the NEU Access Hub, including institutional email, student ID, role, and department.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "studentId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "professor", "guest"] },
        "college": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "blockedReason": { "type": "string" },
        "isAuthorizedAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" },
        "theme": { "type": "string", "enum": ["light", "dark"] }
      },
      "required": ["id", "email", "studentId", "role"]
    },
    "Visit": {
      "title": "Visit",
      "type": "object",
      "description": "Records individual visits to the NEU Library.",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "college": { "type": "string" },
        "roleAtTime": { "type": "string" },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "exitTimestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "academicYear": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "Institutional alerts and system messages sent to users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "warning", "alert"] }
      }
    },
    "LibraryConfig": {
      "title": "LibraryConfig",
      "type": "object",
      "description": "Global operational settings and manual status overrides.",
      "properties": {
        "mode": { "type": "string", "enum": ["automatic", "manual"] },
        "manualStatus": { "type": "string", "enum": ["open", "closed"] },
        "manualReason": { "type": "string" },
        "manualCategory": { "type": "string", "enum": ["general", "emergency", "institutional"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "BlockedUser": {
      "title": "BlockedUser",
      "type": "object",
      "description": "Official registry of suspended institutional accounts.",
      "properties": {
        "userId": { "type": "string" },
        "adminId": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "duration": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles and institutional roles."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": { "$ref": "#/backend/entities/Visit" },
          "description": "Library entry and exit registry."
        }
      },
      {
        "path": "/notifications/{notifId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "User-specific alerts and warnings."
        }
      },
      {
        "path": "/library_config/{configId}",
        "definition": {
          "entityName": "LibraryConfig",
          "schema": { "$ref": "#/backend/entities/LibraryConfig" },
          "description": "Operational mode and status overrides."
        }
      },
      {
        "path": "/blocked_users/{userId}",
        "definition": {
          "entityName": "BlockedUser",
          "schema": { "$ref": "#/backend/entities/BlockedUser" },
          "description": "Official record of a user's suspension."
        }
      }
    ]
  }
}
