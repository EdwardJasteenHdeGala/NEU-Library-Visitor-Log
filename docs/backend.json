
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Stores user profile information for the NEU Access Hub, including institutional email, student ID, role, and department.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "studentId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin", "professor", "guest"] },
        "college": { "type": "string" },
        "isBlocked": { "type": "boolean" },
        "blockedReason": { "type": "string" },
        "isAuthorizedAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "photoURL": { "type": "string" },
        "displayName": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Visit": {
      "title": "Visit",
      "type": "object",
      "description": "Records individual visits to the NEU Library.",
      "properties": {
        "id": { "type": "string" },
        "userName": { "type": "string" },
        "college": { "type": "string" },
        "roleAtTime": { "type": "string" },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "exitTimestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "academicYear": { "type": "string" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "description": "Institutional alerts and system messages sent to users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "warning", "alert"] }
      }
    },
    "LibraryConfig": {
      "title": "LibraryConfig",
      "type": "object",
      "description": "Global operational settings and manual status overrides.",
      "properties": {
        "mode": { "type": "string", "enum": ["automatic", "manual"] },
        "manualStatus": { "type": "string", "enum": ["open", "closed"] },
        "manualReason": { "type": "string" },
        "manualCategory": { "type": "string", "enum": ["general", "emergency", "institutional"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "BlockedUser": {
      "title": "BlockedUser",
      "type": "object",
      "description": "Official registry of suspended institutional accounts.",
      "properties": {
        "userId": { "type": "string" },
        "adminId": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "duration": { "type": "string" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Feedback": {
      "title": "Feedback",
      "type": "object",
      "description": "Institutional sentiments and experience telemetry.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "visitType": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and institutional roles."
    },
    "/visits/{visitId}": {
      "schema": "Visit",
      "description": "Library entry and exit registry."
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User-specific alerts and warnings."
    },
    "/library_config/{configId}": {
      "schema": "LibraryConfig",
      "description": "Operational mode and status overrides."
    },
    "/blocked_users/{userId}": {
      "schema": "BlockedUser",
      "description": "Official record of a user's suspension."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback and sentiments."
    },
    "/audit_logs/{logId}": {
      "schema": "object",
      "description": "Administrative action trail."
    }
  }
}
