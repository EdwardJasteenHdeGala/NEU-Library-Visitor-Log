
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Stores user profile information for the NEU Access Hub, including institutional email, student ID, role, and department. This entity is used for authentication and role-based access control.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's institutional email address (e.g., from the 'neu.edu.ph' domain).",
          "format": "email"
        },
        "studentId": {
          "type": "string",
          "description": "The user's unique student identification number, used for login and identification."
        },
        "role": {
          "type": "string",
          "description": "The assigned role of the user within the application (e.g., 'user', 'admin', 'professor'), determining access privileges."
        },
        "college": {
          "type": "string",
          "description": "The academic department or college the user is affiliated with."
        },
        "isBlocked": {
          "type": "boolean",
          "description": "Indicates if the user is suspended from library access."
        },
        "blockedReason": {
          "type": "string",
          "description": "The official reason provided by an admin for the user's suspension."
        },
        "isAuthorizedAdmin": {
          "type": "boolean",
          "description": "Flag for institutional admin privileges."
        },
        "isSuperAdmin": {
          "type": "boolean",
          "description": "Flag for root system access."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark"],
          "description": "User's preferred interface theme."
        }
      },
      "required": [
        "id",
        "email",
        "studentId",
        "role"
      ]
    },
    "Visit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Visit",
      "type": "object",
      "description": "Records individual visits to the NEU Library, including details about the visitor, their purpose, and the timestamp of their entry.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userName": {
          "type": "string"
        },
        "college": {
          "type": "string"
        },
        "roleAtTime": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "exitTimestamp": {
          "type": "string",
          "format": "date-time"
        },
        "userId": {
          "type": "string"
        },
        "durationMinutes": {
          "type": "number"
        },
        "academicYear": {
          "type": "string"
        }
      }
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "Institutional alerts and system messages sent to users.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "warning", "alert"] }
      }
    },
    "LibraryConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LibraryConfig",
      "type": "object",
      "description": "Global operational settings and manual status overrides.",
      "properties": {
        "mode": { "type": "string", "enum": ["automatic", "manual"] },
        "manualStatus": { "type": "string", "enum": ["open", "closed"] },
        "manualReason": { "type": "string" },
        "manualCategory": { "type": "string", "enum": ["general", "emergency", "institutional"] },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles and institutional roles."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": { "$ref": "#/backend/entities/Visit" },
          "description": "Library entry and exit registry."
        }
      },
      {
        "path": "/notifications/{notifId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "User-specific alerts and warnings."
        }
      },
      {
        "path": "/library_config/{configId}",
        "definition": {
          "entityName": "LibraryConfig",
          "schema": { "$ref": "#/backend/entities/LibraryConfig" },
          "description": "Operational mode and status overrides."
        }
      }
    ]
  }
}
