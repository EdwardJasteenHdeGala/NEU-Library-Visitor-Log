
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's institutional identity and portal access role at New Era University.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "studentId": { "type": "string", "description": "Institutional ID number or PENDING-ID" },
        "role": { "type": "string", "enum": ["guest", "user", "admin"] },
        "college": { "type": "string", "description": "Academic unit or college" },
        "designation": { "type": "string", "enum": ["student", "professor", "staff", "guest"] },
        "isAuthorizedAdmin": { "type": "boolean" },
        "isBlocked": { "type": "boolean" },
        "blockedReason": { "type": "string" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "designation", "createdAt", "updatedAt"]
    },
    "VisitorLogEntry": {
      "title": "VisitorLogEntry",
      "description": "A single entry record for library access.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "college": { "type": "string" },
        "role": { "type": "string" },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "exitTimestamp": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "academicYear": { "type": "string" }
      },
      "required": ["userId", "userName", "college", "purpose", "timestamp"]
    },
    "BlockedUser": {
      "title": "BlockedUser",
      "description": "A record of a suspended user for security rule enforcement.",
      "type": "object",
      "properties": {
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "duration": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Institutional user profiles."
    },
    "/roles_admin/{adminId}": {
      "schema": { "type": "object" },
      "description": "Marker collection for DBAC."
    },
    "/blocked_users/{userId}": {
      "schema": { "$ref": "#/backend/entities/BlockedUser" },
      "description": "Blacklisted identities."
    },
    "/visits/{visitId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLogEntry" },
      "description": "Centralized library access log."
    },
    "/library_config/{configId}": {
      "schema": { "type": "object" },
      "description": "Global operational status configuration."
    },
    "/notifications/{notificationId}": {
      "schema": { "type": "object" },
      "description": "User-specific alerts."
    },
    "/feedback/{feedbackId}": {
      "schema": { "type": "object" },
      "description": "Institutional sentiment telemetry."
    }
  }
}
