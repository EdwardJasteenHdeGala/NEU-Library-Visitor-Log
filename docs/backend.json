
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the NEU Access Hub, including their institutional status (Student, Faculty, Staff) or guest access role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (Firebase UID)."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "studentId": {
          "type": "string",
          "description": "Institutional ID number (Student, Faculty, Employee, or Staff) or 'GUEST' for non-institutional users."
        },
        "role": {
          "type": "string",
          "description": "The current access role: 'guest', 'user', or 'admin'.",
          "enum": ["guest", "user", "admin"]
        },
        "isAuthorizedAdmin": {
          "type": "boolean",
          "description": "Flag indicating if the user is authorized for administrative features."
        },
        "college": {
          "type": "string",
          "description": "The college, department, or 'External' for guests."
        },
        "displayName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of profile creation.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last update.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "studentId",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Visit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Visit",
      "type": "object",
      "description": "Records details of a visitor's entry and exit.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Visit."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the UserProfile UID."
        },
        "userName": {
          "type": "string",
          "description": "Name of the visitor."
        },
        "college": {
          "type": "string",
          "description": "College or 'External'."
        },
        "roleAtTime": {
          "type": "string",
          "description": "Role at the time of visit.",
          "enum": ["guest", "student", "faculty", "staff"]
        },
        "purpose": {
          "type": "string",
          "description": "Purpose of visit.",
          "enum": [
            "reading books",
            "research in thesis",
            "use of computer",
            "doing assignments",
            "group study",
            "consultation",
            "charging device",
            "resting/waiting",
            "printing/scanning",
            "resource borrowing"
          ]
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of the visit entry.",
          "format": "date-time"
        },
        "exitTimestamp": {
          "type": "string",
          "description": "Timestamp of the visit exit.",
          "format": "date-time"
        },
        "durationMinutes": {
          "type": "number",
          "description": "Calculated stay duration in minutes."
        },
        "academicYear": {
          "type": "string",
          "description": "The academic year of the visit."
        }
      },
      "required": [
        "id",
        "userId",
        "userName",
        "purpose",
        "timestamp"
      ]
    },
    "Feedback": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Feedback",
      "type": "object",
      "description": "User submitted feedback about library services.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "visitType": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "message", "timestamp"]
    },
    "LibraryConfig": {
      "title": "LibraryConfig",
      "type": "object",
      "description": "Stores the library's operational configuration, including manual overrides and announcements.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["automatic", "manual"],
          "description": "The current control mode."
        },
        "manualStatus": {
          "type": "string",
          "enum": ["open", "closed"],
          "description": "The status when in manual mode."
        },
        "manualReason": {
          "type": "string",
          "description": "The formal reason/note for manual status change."
        },
        "manualCategory": {
          "type": "string",
          "enum": ["general", "emergency", "institutional"],
          "description": "The classification of the manual override announcement."
        },
        "updatedBy": {
          "type": "string",
          "description": "UID of the admin who last updated the config."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last update."
        }
      },
      "required": ["mode", "updatedAt"]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": {
            "$ref": "#/backend/entities/Visit"
          },
          "description": "Root collection for all library visits."
        }
      },
      {
        "path": "/feedback/{feedbackId}",
        "definition": {
          "entityName": "Feedback",
          "schema": {
            "$ref": "#/backend/entities/Feedback"
          },
          "description": "User feedback submissions."
        }
      },
      {
        "path": "/library_config/{configId}",
        "definition": {
          "entityName": "LibraryConfig",
          "schema": {
            "$ref": "#/backend/entities/LibraryConfig"
          },
          "description": "Global operational configuration."
        }
      }
    ]
  }
}
