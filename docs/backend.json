
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the NEU Access Hub.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "studentId": { "type": "string" },
        "role": { "type": "string", "enum": ["guest", "user", "admin"] },
        "isAuthorizedAdmin": { "type": "boolean" },
        "isSuperAdmin": { "type": "boolean" },
        "college": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "theme": { "type": "string", "enum": ["light", "dark"], "default": "light" }
      },
      "required": ["id", "email", "role", "createdAt", "updatedAt"]
    },
    "Visit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Visit",
      "type": "object",
      "description": "Records details of a visitor's entry and exit.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "college": { "type": "string" },
        "roleAtTime": { "type": "string", "enum": ["guest", "user", "admin"] },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "exitTimestamp": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "academicYear": { "type": "string" }
      },
      "required": ["id", "userId", "userName", "purpose", "timestamp"]
    },
    "AuditLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AuditLog",
      "type": "object",
      "description": "Administrative action logs.",
      "properties": {
        "id": { "type": "string" },
        "adminId": { "type": "string" },
        "adminName": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "action", "timestamp"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "type": "object",
      "description": "User notifications.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "timestamp"]
    },
    "LibraryConfig": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "LibraryConfig",
      "type": "object",
      "description": "Global institutional library state.",
      "properties": {
        "mode": { "type": "string", "enum": ["automatic", "manual"] },
        "manualStatus": { "type": "string", "enum": ["open", "closed"] },
        "manualReason": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profiles."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": { "$ref": "#/backend/entities/Visit" },
          "description": "Library visits."
        }
      },
      {
        "path": "/audit_logs/{logId}",
        "definition": {
          "entityName": "AuditLog",
          "schema": { "$ref": "#/backend/entities/AuditLog" },
          "description": "Administrative audit trail."
        }
      },
      {
        "path": "/notifications/{notificationId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "User notifications."
        }
      },
      {
        "path": "/feedback/{feedbackId}",
        "definition": {
          "entityName": "Feedback",
          "schema": { "$ref": "#/backend/entities/Feedback" },
          "description": "User feedback."
        }
      },
      {
        "path": "/library_config/{configId}",
        "definition": {
          "entityName": "LibraryConfig",
          "schema": { "$ref": "#/backend/entities/LibraryConfig" },
          "description": "Institutional operational state."
        }
      }
    ]
  }
}
