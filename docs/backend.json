
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's institutional identity and portal access role at New Era University.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "studentId": { "type": "string", "description": "Institutional ID number or PENDING-ID" },
        "role": { "type": "string", "enum": ["guest", "user", "admin"] },
        "department": { "type": "string", "description": "Academic unit or college" },
        "designation": { "type": "string", "enum": ["student", "professor", "staff", "guest"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "designation", "createdAt", "updatedAt"]
    },
    "VisitorLogEntry": {
      "title": "VisitorLogEntry",
      "description": "A single entry record for library access.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "college": { "type": "string" },
        "role": { "type": "string", "description": "Institutional designation at time of visit" },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "academicYear": { "type": "string" }
      },
      "required": ["userId", "name", "college", "role", "purpose", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Private user profiles managed by the owner."
    },
    "/roles_admin/{adminId}": {
      "schema": { "type": "object" },
      "description": "Marker collection for Database Access Control (DBAC)."
    },
    "/visits/{visitId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLogEntry" },
      "description": "Centralized library access log."
    }
  }
}
