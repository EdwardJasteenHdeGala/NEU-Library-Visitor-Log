
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Represents a user's institutional identity and portal access role at New Era University.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "studentId": { "type": "string", "description": "Institutional ID number or PENDING-ID" },
        "role": { "type": "string", "enum": ["guest", "user", "admin"] },
        "college": { "type": "string", "description": "Academic unit or college" },
        "designation": { "type": "string", "enum": ["student", "professor", "staff", "guest"] },
        "isAuthorizedAdmin": { "type": "boolean" },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role", "designation", "createdAt", "updatedAt"]
    },
    "VisitorLogEntry": {
      "title": "VisitorLogEntry",
      "description": "A single entry record for library access.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "college": { "type": "string" },
        "role": { "type": "string" },
        "purpose": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "exitTimestamp": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "academicYear": { "type": "string" }
      },
      "required": ["userId", "userName", "college", "purpose", "timestamp"]
    },
    "LibraryConfig": {
      "title": "LibraryConfig",
      "description": "Global operational settings for the library hub.",
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["automatic", "manual"] },
        "manualStatus": { "type": "string", "enum": ["open", "closed"] },
        "manualReason": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "A system alert or message for a specific user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "read", "timestamp"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User sentiment and rating telemetry.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "rating": { "type": "number" },
        "visitType": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "rating", "message", "timestamp"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Institutional user profiles."
    },
    "/roles_admin/{adminId}": {
      "schema": { "type": "object" },
      "description": "Marker collection for DBAC."
    },
    "/visits/{visitId}": {
      "schema": { "$ref": "#/backend/entities/VisitorLogEntry" },
      "description": "Centralized library access log."
    },
    "/library_config/{configId}": {
      "schema": { "$ref": "#/backend/entities/LibraryConfig" },
      "description": "Global operational status configuration."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/backend/entities/Notification" },
      "description": "User-specific alerts."
    },
    "/feedback/{feedbackId}": {
      "schema": { "$ref": "#/backend/entities/Feedback" },
      "description": "Institutional sentiment telemetry."
    }
  }
}
