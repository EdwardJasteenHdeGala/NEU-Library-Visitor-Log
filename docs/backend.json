
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within the NEU Access Hub, including their institutional status or guest access role.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity (Firebase UID)."
        },
        "email": {
          "type": "string",
          "description": "The email address of the user.",
          "format": "email"
        },
        "studentId": {
          "type": "string",
          "description": "The student identification number or 'GUEST' for non-institutional users."
        },
        "role": {
          "type": "string",
          "description": "The current access role: 'guest', 'user', or 'admin'.",
          "enum": ["guest", "user", "admin"]
        },
        "isAuthorizedAdmin": {
          "type": "boolean",
          "description": "Flag indicating if the user is authorized for administrative features."
        },
        "college": {
          "type": "string",
          "description": "The college, department, or 'External' for guests."
        },
        "displayName": {
          "type": "string",
          "description": "The full name of the user."
        },
        "photoURL": {
          "type": "string",
          "description": "The URL of the user's profile picture."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of profile creation.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of last update.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "email",
        "studentId",
        "role",
        "createdAt",
        "updatedAt"
      ]
    },
    "Visit": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Visit",
      "type": "object",
      "description": "Records details of a visitor's entry.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Visit."
        },
        "userId": {
          "type": "string",
          "description": "Reference to the UserProfile UID."
        },
        "userName": {
          "type": "string",
          "description": "Name of the visitor."
        },
        "college": {
          "type": "string",
          "description": "College or 'External'."
        },
        "roleAtTime": {
          "type": "string",
          "description": "Role at the time of visit.",
          "enum": ["guest", "student", "faculty", "staff"]
        },
        "purpose": {
          "type": "string",
          "description": "Purpose of visit.",
          "enum": [
            "reading books",
            "research in thesis",
            "use of computer",
            "doing assignments",
            "group study",
            "consultation",
            "charging device",
            "resting/waiting",
            "printing/scanning",
            "resource borrowing"
          ]
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of the visit entry.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "userName",
        "purpose",
        "timestamp"
      ]
    }
  },
  "auth": {
    "providers": [
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/user_profiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profiles."
        }
      },
      {
        "path": "/visits/{visitId}",
        "definition": {
          "entityName": "Visit",
          "schema": {
            "$ref": "#/backend/entities/Visit"
          },
          "description": "Root collection for all library visits."
        }
      }
    ]
  }
}
