rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL RBAC HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'nhica.valderas@neu.edu.ph'
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // USER PROFILES
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // VISITS REGISTRY
    match /visits/{visitId} {
      // Split list rules to ensure query-wide access for admins
      // and filtered access for standard members.
      allow list: if isAuthenticated() && isAdmin();
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Retrieval and creation
      allow get: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      
      // Administrative modifications
      allow update, delete: if isAdmin();
    }

    // INSTITUTIONAL CONFIG
    match /library_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTIFICATIONS & ALERTS
    match /notifications/{notificationId} {
      allow list: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow get: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, write: if isAdmin();
    }

    // FEEDBACK TELEMETRY
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow list: if isAdmin();
      allow get: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // AUDIT TRAIL
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}