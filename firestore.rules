rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL RBAC HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }

    // Simplified admin check to prevent recursion
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "edwardjasteen.degala@neu.edu.ph" ||
        request.auth.token.email == "jcesperanza@neu.edu.ph" ||
        request.auth.token.email == "nhica.valderas@neu.edu.ph"
      );
    }

    // USER PROFILES
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // VISITS REGISTRY
    match /visits/{visitId} {
      allow read, write, list: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      allow list: if isAuthenticated() && (
         request.query.filters.size() > 0 && 
         request.query.filters[0].field == 'userId' && 
         request.query.filters[0].op == '==' && 
         request.query.filters[0].value == request.auth.uid
      );
    }

    // INSTITUTIONAL CONFIG
    match /library_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTIFICATIONS
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, write: if isAdmin();
    }

    // FEEDBACK
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // AUDIT TRAIL
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}