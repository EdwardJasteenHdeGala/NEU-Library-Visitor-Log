rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isAnyAdmin() {
      return isBootstrapAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && (getUserData().role == 'admin' || getUserData().isSuperAdmin == true));
    }

    function isSuperAdmin() {
      return isBootstrapAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && getUserData().isSuperAdmin == true);
    }

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAnyAdmin();
      allow list: if isAnyAdmin();
      allow create: if isOwner(userId) || isAnyAdmin();
      allow update: if isOwner(userId) || isAnyAdmin();
      allow delete: if isSuperAdmin();
    }

    match /visits/{visitId} {
      // Allow read (get + list) for all institutional members to see occupancy telemetry and personal history
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /feedback/{feedbackId} {
      allow list: if isAnyAdmin();
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /library_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
  }
}