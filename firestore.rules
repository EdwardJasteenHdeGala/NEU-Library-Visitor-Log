rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL RBAC HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        // Prioritized Email Whitelist for immediate administrative authorization
        request.auth.token.email == "edwardjasteen.degala@neu.edu.ph" ||
        request.auth.token.email == "jcesperanza@neu.edu.ph" ||
        request.auth.token.email == "nhica.valderas@neu.edu.ph" ||
        (
          // Document-based check for manually synchronized administrators
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    // USER PROFILES
    match /users/{userId} {
      // Users manage their own identity; Admins maintain institutional oversight
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // VISITS REGISTRY
    match /visits/{visitId} {
      // Admins are authorized for full registry oversight
      allow get, write: if isAdmin();
      allow list: if isAdmin();

      // Standard members can log their presence and read their own records
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Allow standard users to list their own visits if properly filtered
      allow list: if isAuthenticated() && (
         request.query.limit <= 100 && 
         request.query.filters.size() > 0 && 
         request.query.filters[0].field == 'userId' && 
         request.query.filters[0].op == '==' && 
         request.query.filters[0].value == request.auth.uid
      );
    }

    // INSTITUTIONAL CONFIG (ANNOUNCEMENTS/NOTICES)
    match /library_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTIFICATIONS & ALERTS
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, write: if isAdmin();
    }

    // FEEDBACK TELEMETRY
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // AUDIT TRAIL
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}