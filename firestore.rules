rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        // WHU-WHU BOOTSTRAP: Hardcoded institutional owner (case-insensitive)
        ('email' in request.auth.token && request.auth.token.email.lower() == 'edwardjasteen.degala@neu.edu.ph') ||
        // DYNAMIC AUTHORITY: Check for explicit role assignment in identity registry
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') == 'superadmin')
      );
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && (
          // Whitelisted administrative emails
          ('email' in request.auth.token && (
            request.auth.token.email.lower() == 'jcesperanza@neu.edu.ph' ||
            request.auth.token.email.lower() == 'nhica.valderas@neu.edu.ph'
          )) ||
          // Registry-based administrative authority check
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'member') == 'admin' && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false)
        )
      );
    }

    function isMember() {
      return isSignedIn() && (
        // Institutional email requirement
        ('email' in request.auth.token && request.auth.token.email.lower().matches('.*@neu\\.edu\\.ph')) ||
        // Identity verified in registry and not restricted
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false)
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /visits/{visitId} {
      // INSTITUTIONAL OVERRIDE: Admins see all logs. Members see only their own.
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Only authorized members or admins can register presence.
      allow create: if isMember() || isAdmin();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /advisories/{advisoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /invites/{inviteId} {
      allow read: if isAdmin() || (isSignedIn() && 'email' in request.auth.token && request.auth.token.email.lower() == resource.data.email.lower());
      allow write: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /role_audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    match /system_diagnostics/{logId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /borrowings/{borrowingId} {
      // Members can see their own borrowings. Admins see all.
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      // Anyone signed in can initiate a borrowing (the transaction handles inventory).
      allow create: if isSignedIn();
      // Only admins can update status (return/renew) or delete.
      allow update, delete: if isAdmin();
    }

    match /books_inventory/{bookId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
