
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Requested permissive rule for institutional registry
    match /visits/{visitId} {
      allow read, write: if true;
    }

    // Critical institutional rules for portal functionality
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    match /library_config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /notifications/{id} {
      allow read, write: if request.auth != null;
    }

    match /feedback/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /roles_admin/{id} {
      allow read, write: if request.auth != null;
    }

    match /blocked_users/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /audit_logs/{id} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
