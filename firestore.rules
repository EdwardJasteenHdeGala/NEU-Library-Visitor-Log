rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Optimized admin check prioritizes email whitelist for immediate access.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() in [
          'edwardjasteen.degala@neu.edu.ph', 
          'jcesperanza@neu.edu.ph', 
          'nhica.valderas@neu.edu.ph'
        ] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Root level visits collection rule - secured for institutional oversight
    match /visits/{visitId} {
      // Admins see all. Users see only their own.
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      // Listing is allowed for admins. Users can list if they apply a filter for their own UID.
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100); 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /invites/{inviteId} {
      // Allow newly signed-in users to query for their inheritance role
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == resource.data.email.lower());
      allow write: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}