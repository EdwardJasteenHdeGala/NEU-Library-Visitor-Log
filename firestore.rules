
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Direct email check for core admins to avoid recursion and rule evaluation limits
      let adminEmails = [
        "edwardjasteen.degala@neu.edu.ph",
        "jcesperanza@neu.edu.ph",
        "nhica.valderas@neu.edu.ph"
      ];
      return isSignedIn() && (
        request.auth.token.email in adminEmails || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isNotBlocked() {
      return isSignedIn() && !exists(/databases/$(database)/documents/blocked_users/$(request.auth.uid));
    }

    // --- Collections ---

    // USERS: Institutional profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // VISITS: Library access logs
    // Simplified read rule to allow collection-wide list operations for authenticated users
    match /visits/{visitId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBlocked();
      allow update, delete: if isAdmin();
    }

    // NOTIFICATIONS: User alerts
    // Synchronized with the successful patterns for telemetry collections
    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }

    // FEEDBACK: Institutional sentiments
    match /feedback/{feedbackId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isNotBlocked();
      allow update, delete: if isAdmin();
    }

    // CONFIG: Global operational status
    match /library_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ADMIN ROLES: Marker collection for DBAC
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // BLOCKED USERS: Security blacklist
    match /blocked_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // AUDIT: Admin action trail
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    
    // Default fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
