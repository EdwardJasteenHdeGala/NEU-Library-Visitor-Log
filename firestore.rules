rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL RBAC HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }

    // Prioritized Administrative Whitelist for immediate registry oversight.
    // Checking the token email directly avoids recursive get() calls during initial auth sync.
    // Deployment Trigger Comment: Synchronizing administrative gateway protocols.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "edwardjasteen.degala@neu.edu.ph" ||
        request.auth.token.email == "jcesperanza@neu.edu.ph" ||
        request.auth.token.email == "nhica.valderas@neu.edu.ph"
      );
    }

    // USER PROFILES
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // VISITS REGISTRY
    match /visits/{visitId} {
      // Admins authorized for full registry oversight
      allow read, write, list: if isAdmin();

      // Standard members can log presence and read own records
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Allow standard users to list their own visits if properly filtered.
      allow list: if isAuthenticated() && (
         request.query.filters.size() > 0 && 
         request.query.filters[0].field == 'userId' && 
         request.query.filters[0].op == '==' && 
         request.query.filters[0].value == request.auth.uid
      );
    }

    // INSTITUTIONAL CONFIG (ANNOUNCEMENTS/NOTICES)
    match /library_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTIFICATIONS & ALERTS
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, write: if isAdmin();
    }

    // FEEDBACK TELEMETRY
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // AUDIT TRAIL
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}