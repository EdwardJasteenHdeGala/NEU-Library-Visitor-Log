
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAnyAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /user_profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow delete: if isAnyAdmin();
    }

    match /visits/{visitId} {
      // Allow list for all authenticated users to resolve registry sync errors
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /feedback/{feedbackId} {
      allow list: if isAnyAdmin();
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAnyAdmin();
      allow create: if isAnyAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAnyAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /library_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
  }
}
