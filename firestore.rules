rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Fast-path check for the bootstrap super admin via email token.
     */
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isAnyAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
        (getUserData().role == 'admin' || getUserData().isSuperAdmin == true)
      );
    }

    function isSuperAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
        getUserData().isSuperAdmin == true
      );
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isOwner(userId) || isAnyAdmin();
      allow list: if isAnyAdmin();
      allow create: if isOwner(userId) || isAnyAdmin();
      allow update: if isOwner(userId) || isAnyAdmin();
      allow delete: if isSuperAdmin();
    }

    match /visits/{visitId} {
      /**
       * Secure List Access:
       * 1. Admins see everything.
       * 2. Authenticated institutional members can perform list operations if they:
       *    a) Filter by their own userId (Personal History).
       *    b) Filter by exitTimestamp == null (Occupancy Telemetry).
       */
      allow list: if isSignedIn() && (
        isAnyAdmin() || 
        request.query.userId == request.auth.uid || 
        request.query.exitTimestamp == null
      );
      
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /feedback/{feedbackId} {
      allow list: if isAnyAdmin();
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /library_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
  }
}