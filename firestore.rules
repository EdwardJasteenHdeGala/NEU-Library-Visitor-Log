rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access Hub - Institutional Security Protocols
     */

    // Helper: Checks if the user is a hardcoded administrator
    function isHardcodedAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'nhica.valderas@neu.edu.ph'
      );
    }

    // Helper: Checks if the user is a database-verified admin
    // We avoid checking this for the user's own document to prevent recursion
    function isDbAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Master admin check (Hardcoded check first to avoid DB hits)
    function isAdmin() {
      return isHardcodedAdmin() || isDbAdmin();
    }

    // Helper: Checks if the user is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USERS collection: Identity management
    match /users/{userId} {
      // Priority: Self-access (prevents recursion)
      allow read, write: if isOwner(userId);
      // Fallback: Admin oversight
      allow read, write: if isAdmin();
    }

    // VISITS collection: Registry of library entries
    match /visits/{visitId} {
      // Admins have absolute registry oversight
      allow read, write: if isAdmin();
      
      // Standard members: Can log entry
      allow create: if request.auth != null;
      // Can read own history or when admin is verified
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
    }
    
    // NOTIFICATIONS: Alert center
    match /notifications/{notifId} {
      // Admins have absolute control
      allow read, write: if isAdmin();
      // Users can read their own notifications
      allow read: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      // Users can mark their own as read (update)
      allow update: if request.auth != null && (resource != null && resource.data.userId == request.auth.uid);
    }

    // LIBRARY_CONFIG: Operational status and manual overrides
    match /library_config/{configId} {
      // All institutional members need to see if the library is open
      allow read: if request.auth != null;
      // Only admins can override the operational status
      allow write: if isAdmin();
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}