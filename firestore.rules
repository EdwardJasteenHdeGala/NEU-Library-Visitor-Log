rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Optimized admin check
    function isAnyAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Collection: user_profiles
    match /user_profiles/{userId} {
      // Users can always read their own profile; Admins can read all profiles.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow delete: if isAnyAdmin();
    }

    // Collection: visits
    match /visits/{visitId} {
      // Allow list and get for all authenticated users to enable occupancy telemetry and personal logs.
      allow read: if isSignedIn();
      // Users can only create logs for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      // Only admins can modify or purge the registry.
      allow update, delete: if isAnyAdmin();
    }

    // Collection: library_config
    match /library_config/{configId} {
      // Institutional state must be visible to all portal members.
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Collection: feedback
    match /feedback/{feedbackId} {
      allow list: if isAnyAdmin();
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    // Collection: audit_logs
    match /audit_logs/{logId} {
      allow read, create: if isAnyAdmin();
    }

    // Collection: notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAnyAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}