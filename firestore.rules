
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for institutional authorization
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user is an authorized administrator
    // Prioritizes master email and uses a marker collection check for efficiency
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. VISITS REGISTRY - FIXED FOR LIST PERMISSION
    match /visits/{visitId} {
      // DEBUG/TESTING: Allow all authenticated members to list/get logs
      // This line fixes the "Missing or insufficient permissions" on 'list'
      allow read: if isAuthenticated();
      
      // PRODUCTION (Optional/Secure): 
      // allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Authorized writes: Admins have full control, members can create their own logs
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // 2. USER PROFILES
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(userId);
    }

    // 3. ADMIN MARKERS
    match /roles_admin/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 4. OPERATIONAL CONFIG
    match /library_config/{configId} {
      allow read: if true; // Publicly readable for the Welcome Screen status
      allow write: if isAdmin();
    }

    // 5. NOTIFICATIONS & ALERTS
    match /notifications/{id} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 6. SENTIMENT FEEDBACK
    match /feedback/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // 7. SECURITY BLACKLIST
    match /blocked_users/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // 8. ADMINISTRATIVE AUDIT TRAIL
    match /audit_logs/{id} {
      allow read, write: if isAdmin();
    }

    // Global Deny-All fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
