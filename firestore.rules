rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // EXPERIMENTAL PERMISSION START
    // This allows global read/write access for authenticated users to facilitate 
    // registry synchronization and administrative oversight debugging.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Helper to check for administrative privileges
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // INSTITUTIONAL RBAC PROTOCOLS
    match /users/{userId} {
      // Allow members to manage their own identity registry
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read: if isAdmin();
    }

    match /visits/{visitId} {
      // Allow all authenticated users (including guests) to log attendance
      allow create: if request.auth != null;
      
      // Allow members to read their own logs and admins to see the full registry
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        isAdmin()
      );
      
      allow write: if isAdmin();
    }

    match /library_config/{configId} {
      // Publicly readable for real-time operational status on the Welcome Page
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

  }
}