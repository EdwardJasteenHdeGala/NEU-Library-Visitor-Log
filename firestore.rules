rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // SYSTEM FUNCTIONS & FAILSAFE WHITELIST
    // -------------------------------------------------------------------------
    
    // Failsafe, high-priority whitelist bypass for the Institutional Owner
    // Uses UID as the ultimate source of truth, with email as a fallback.
    function isSuperAdmin() {
      return request.auth != null && 
             (request.auth.uid == 'ix6skGzgoCM0v8BpiT4dtsbEkys2' || 
              (request.auth.token.email != null && 
               request.auth.token.email.lower() == 'edwardjasteen.degala@neu.edu.ph'));
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAuthorizedAdmin() {
      return isSuperAdmin() || 
             (isAuthenticated() && 
              exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
              (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin' ||
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAuthorizedAdmin == true));
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    // 1. Visits Collection
    match /visits/{visitId} {
      // Super Admins and Admins can list/read all. Users can only read their own.
      allow read, list: if isSuperAdmin() || isAuthorizedAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin() || isAuthorizedAdmin();
    }

    // 2. Users Collection
    match /users/{userId} {
      // Admin/SuperAdmin bypass for management. Users can read/write their own basic info.
      allow read: if isSuperAdmin() || isAuthorizedAdmin() || isOwner(userId);
      allow write: if isSuperAdmin() || isAuthorizedAdmin() || isOwner(userId);
    }

    // 3. Configurations (Public for Kernel crashes fix)
    match /configurations/{docId} {
      // Must be public for initial system startup / Kernel Panic prevention
      allow read: if isAuthenticated() || true; 
      allow write: if isSuperAdmin();
    }

    // 4. Role Audit Logs
    match /role_audit_logs/{logId} {
      allow read: if isSuperAdmin() || isAuthorizedAdmin();
      allow create: if isSuperAdmin() || isAuthorizedAdmin();
      allow update, delete: if false; // Immutable
    }
    
    // 5. Notifications
    match /notifications/{notificationId} {
      allow read: if isSuperAdmin() || isAuthorizedAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isSuperAdmin() || isAuthorizedAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }
    
    // 6. Invites
    match /invites/{inviteId} {
      allow read: if isSuperAdmin() || isAuthorizedAdmin() || (isAuthenticated() && resource.data.email.lower() == request.auth.token.email.lower());
      allow write: if isSuperAdmin() || isAuthorizedAdmin();
    }

    // Default catch-all
    match /{document=**} {
      // Final failsafe: If nothing else matches, Super Admin still has access
      allow read, write: if isSuperAdmin();
    }
  }
}
