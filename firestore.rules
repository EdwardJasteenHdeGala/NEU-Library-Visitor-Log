
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access Hub - Institutional Security Protocols
     */

    // Helper: Checks if the user is a hardcoded administrator (Fastest)
    function isHardcodedAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'nhica.valderas@neu.edu.ph'
      );
    }

    // Helper: Checks if the user is a database-verified admin (Requires document fetch)
    function isDbAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Master admin check
    function isAdmin() {
      return isHardcodedAdmin() || isDbAdmin();
    }

    // Helper: Checks if the user is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Checks if the user is NOT blocked
    function isNotBlocked() {
      return request.auth != null && (
        !exists(/databases/$(database)/documents/blocked_users/$(request.auth.uid)) ||
        (get(/databases/$(database)/documents/blocked_users/$(request.auth.uid)).data.expiresAt != null &&
         get(/databases/$(database)/documents/blocked_users/$(request.auth.uid)).data.expiresAt < request.time)
      );
    }

    // USERS: Identity management
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isHardcodedAdmin();
    }

    // NOTIFICATIONS: Alert center
    match /notifications/{notifId} {
      // Apply successful pattern: Allow authenticated read, privacy handled by query filters
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if request.auth != null && isNotBlocked() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // VISITS: Registry of library entries
    match /visits/{visitId} {
      // Apply successful pattern: Allow authenticated read, privacy handled by query filters
      allow read: if request.auth != null;
      allow create: if request.auth != null && isNotBlocked();
      allow update, delete: if isAdmin();
    }
    
    // FEEDBACK: Institutional sentiments
    match /feedback/{feedbackId} {
      // Apply successful pattern: Allow authenticated read, privacy handled by query filters
      allow read: if request.auth != null;
      allow create: if request.auth != null && isNotBlocked();
      allow update, delete: if isAdmin();
    }

    // LIBRARY_CONFIG: Operational status and manual overrides
    match /library_config/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // BLOCKED_USERS: Access revocation registry
    match /blocked_users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // AUDIT_LOGS: Administrative action trail
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
