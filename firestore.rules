
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // EXPERIMENTAL PERMISSION START
    // This allows global read/write access for authenticated users to facilitate 
    // registry synchronization and administrative oversight debugging.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // INSTITUTIONAL OVERRIDE (Optional Debug)
    // match /visits/{visitId} {
    //   allow read, write: if true;
    // }

  }
}
