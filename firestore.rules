rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Visitor Log - Institutional Security Rules
     */

    // Helper: Checks if the user is an admin based on the users collection
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper: Checks if the user owns the document
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USERS collection: Primary identity records
    match /users/{userId} {
      // Allow authenticated users to read/write their own user document
      allow read, write: if isOwner(userId);
      
      // Allow admins to manage all user records
      allow read, write: if isAdmin();
    }

    // VISITS collection: Registry of library entries
    match /visits/{visitId} {
      // Allow admins to read/write the entire visits collection
      allow read, write: if isAdmin();

      // Allow authenticated users to create their own visit entry
      allow create: if request.auth != null;

      // Allow users to see their own history (Required for active session tracking)
      allow list, get: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}