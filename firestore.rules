
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Check if the user has the 'admin' role in their profile
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Helper: Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // 1. USER PROFILES
    // Users can read/write their own profile; admins have full access.
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // 2. VISITS REGISTRY
    // Authenticated users (members & guests) can create their own logs.
    // Admins can read/write the entire collection.
    // Regular users can read only their own logs.
    match /visits/{visitId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // 3. ADMIN MARKERS (Optional but useful for DBAC)
    match /roles_admin/{adminId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 4. OPERATIONAL CONFIG
    match /library_config/{configId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 5. NOTIFICATIONS & ALERTS
    match /notifications/{id} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // 6. SENTIMENT FEEDBACK
    match /feedback/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    
    // 7. SECURITY BLACKLIST
    match /blocked_users/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // 8. ADMINISTRATIVE AUDIT TRAIL
    match /audit_logs/{id} {
      allow read, write: if isAdmin();
    }

    // Global Deny-All fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
