rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access Hub - Institutional Security Protocols
     */

    // Helper: Checks if the user is an authorized admin via profile data
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAuthorizedAdmin == true;
    }

    // Helper: Checks if the user is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // USERS collection: Identity management
    match /users/{userId} {
      // Allow users to manage their own profile
      allow read, write: if isOwner(userId);
      
      // Allow admins to manage all institutional records
      allow read, write: if isAdmin();
    }

    // VISITS collection: Registry of library entries
    match /visits/{visitId} {
      // Allow admins full oversight
      allow read, write: if isAdmin();

      // Allow all authenticated users to log entries
      allow create: if request.auth != null;

      // Allow authenticated users to list visits (must still filter to see docs they own unless admin)
      allow list: if request.auth != null;
      allow get: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
    }
    
    // CONFIGURATION: System-wide settings
    match /library_config/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // FEEDBACK collection: Institutional sentiments
    match /feedback/{feedbackId} {
      allow create: if request.auth != null;
      allow read: if isAdmin();
    }
    
    // AUDIT_LOGS collection: Administrative trail
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // NOTIFICATIONS: Alert center
    match /notifications/{notifId} {
      // Allow authenticated users to list notifications
      allow list: if request.auth != null;
      allow get, update: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, delete: if isAdmin();
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}