rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL RBAC HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // USER PROFILES
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // VISITS REGISTRY
    match /visits/{visitId} {
      // Admins can list, read, and write all visits
      allow read, write: if isAdmin();

      // All authenticated users can create new visits
      allow create: if isAuthenticated();
      
      // Allow users to read their own visits (for active session check)
      // Note: Listing requires a query filter matching this condition
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // INSTITUTIONAL CONFIG
    match /library_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTIFICATIONS & ALERTS
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin()
      );
      allow create, write: if isAdmin();
    }

    // FEEDBACK TELEMETRY
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // AUDIT TRAIL
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}