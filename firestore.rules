
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access Hub - Institutional Security Protocols
     */

    // Helper: Checks if the user is an authorized admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'nhica.valderas@neu.edu.ph' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Helper: Checks if the user is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Checks if the user is NOT suspended
    function isNotBlocked() {
      // Allow access if profile doesn't exist yet (onboarding phase)
      // or if it exists and isBlocked is not explicitly true
      return request.auth != null && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true
      );
    }

    // USERS collection: Identity management
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow write for own profile (onboarding) or admin oversight
      allow write: if isOwner(userId) || isAdmin();
    }

    // VISITS collection: Registry of library entries
    match /visits/{visitId} {
      // Admins have absolute registry oversight
      allow read, write: if isAdmin();
      
      // Standard members
      allow create: if request.auth != null && isNotBlocked();
      // Allow reading own history or when admin is verified
      allow get, list: if request.auth != null && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
    }
    
    // NOTIFICATIONS: Alert center
    match /notifications/{notifId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // LIBRARY_CONFIG: Operational status and manual overrides
    match /library_config/{configId} {
      // All institutional members need to see if the library is open
      allow read: if request.auth != null;
      // Only admins can override the operational status
      allow write: if isAdmin();
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
