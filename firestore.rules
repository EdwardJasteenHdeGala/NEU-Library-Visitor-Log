
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access Hub - Institutional Security Protocols
     */

    // Helper: Checks if the user is an authorized admin via profile data
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Checks if the user is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Checks if the user is suspended
    function isNotBlocked() {
      return request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked != true;
    }

    // USERS collection: Identity management
    match /users/{userId} {
      // Allow users to read their own profile even if blocked (to see status)
      // But only allow write if NOT blocked
      allow read: if isOwner(userId) || isAdmin();
      allow write: if (isOwner(userId) && isNotBlocked()) || isAdmin();
    }

    // VISITS collection: Registry of library entries
    match /visits/{visitId} {
      allow read, write: if isAdmin();
      
      // Standard members can list their own visits if NOT blocked
      allow create: if request.auth != null && isNotBlocked();
      allow get, list: if request.auth != null && (isAdmin() || (resource.data.userId == request.auth.uid && isNotBlocked()));
    }
    
    // NOTIFICATIONS: Alert center
    match /notifications/{notifId} {
      allow read, write: if isAdmin();
      // Users can only read their own notifications
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
