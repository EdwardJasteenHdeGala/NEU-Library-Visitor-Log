rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // INSTITUTIONAL RBAC HELPERS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // USER PROFILES
    match /users/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // VISITS REGISTRY
    match /visits/{visitId} {
      // Admins can list, read, and write all visits
      // Standard members can read their own logs but cannot list the entire collection
      allow read, write: if isAuthenticated() && (isAdmin() || (resource != null && resource.data.userId == request.auth.uid));
      
      // All authenticated members can create new registry entries
      allow create: if isAuthenticated();
    }

    // INSTITUTIONAL CONFIG
    match /library_config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // NOTIFICATIONS & ALERTS
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create, write: if isAdmin();
    }

    // FEEDBACK TELEMETRY
    match /feedback/{feedbackId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // AUDIT TRAIL
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}