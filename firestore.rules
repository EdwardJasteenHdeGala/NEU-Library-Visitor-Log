
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEU Library Access Hub - Institutional Security Protocols
     * Optimized for performance and recursion prevention.
     */

    // Helper: Checks if the user is a hardcoded administrator (Fastest)
    function isHardcodedAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email == 'nhica.valderas@neu.edu.ph'
      );
    }

    // Helper: Checks if the user is a database-verified admin
    function isDbAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Master admin check
    function isAdmin() {
      // Use hardcoded check as primary for speed and reliability
      if (isHardcodedAdmin()) {
        return true;
      }
      // Fallback to database check
      return isDbAdmin();
    }

    // Helper: Checks if the user is the document owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Helper: Checks if the user is NOT blocked
    function isNotBlocked() {
      // Allow if the block document doesn't exist (most common case)
      return request.auth != null && !exists(/databases/$(database)/documents/blocked_users/$(request.auth.uid));
    }

    // UNIVERSAL READ: All authenticated users can read standard registries.
    // The application handles privacy via query filters (e.g., .where('userId', '==', uid)).

    // USERS: Identity management
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if isOwner(userId) || isHardcodedAdmin();
    }

    // NOTIFICATIONS: Alert center
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow create: if isAdmin();
      allow update: if request.auth != null && (isOwner(resource.data.userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // VISITS: Registry of library entries
    match /visits/{visitId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isNotBlocked();
      allow update, delete: if isAdmin();
    }
    
    // FEEDBACK: Institutional sentiments
    match /feedback/{feedbackId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isNotBlocked();
      allow update, delete: if isAdmin();
    }

    // LIBRARY_CONFIG: Operational status and manual overrides
    match /library_config/{configId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // BLOCKED_USERS: Access revocation registry
    match /blocked_users/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // AUDIT_LOGS: Administrative action trail
    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
    }

    // Default deny for all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
