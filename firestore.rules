rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Utility functions
    function isSignedIn() {
      return request.auth != null;
    }

    // Optimized admin check - avoids recursion by using token email first
    // and ensuring profile lookup is safe.
    function isAnyAdmin() {
      let email = request.auth.token.email;
      return isSignedIn() && (
        email == 'edwardjasteen.degala@neu.edu.ph' ||
        email == 'jcesperanza@neu.edu.ph' ||
        // Defensive check: only use get() if the document exists to avoid evaluation errors
        (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Collection: user_profiles
    match /user_profiles/{userId} {
      // Users can always read and update their own profile
      allow get, update: if isSignedIn() && request.auth.uid == userId;
      
      // Admins can manage all profiles
      // We use a more direct check here to avoid recursion within the same collection
      allow get, list, update, delete: if isSignedIn() && (
        request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email == 'jcesperanza@neu.edu.ph' ||
        (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.role == 'admin')
      );

      // Support for the invitation/claiming mechanism
      allow list: if isSignedIn() && (
        resource.data.email == request.auth.token.email || 
        request.auth.uid == userId
      );

      allow create: if isSignedIn() && request.auth.uid == userId;
    }

    // Collection: visits
    match /visits/{visitId} {
      // Allow read (get and list) if the user is an admin OR if they are accessing their own data.
      // For listing, this requires the client to filter by userId.
      allow list: if isSignedIn() && (
        isAnyAdmin() || 
        (request.query.limit <= 50 && resource.data.userId == request.auth.uid)
      );
      
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      
      // Users can only create logs for themselves.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Only admins can modify or purge the registry.
      allow update, delete: if isAnyAdmin();
    }

    // Collection: library_config
    match /library_config/{configId} {
      // Institutional state must be visible to all portal members.
      allow get, list: if isSignedIn();
      allow write: if isAnyAdmin();
    }

    // Collection: feedback
    match /feedback/{feedbackId} {
      allow list: if isAnyAdmin();
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    // Collection: audit_logs
    match /audit_logs/{logId} {
      allow read, create: if isAnyAdmin();
    }

    // Collection: notifications
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isAnyAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}