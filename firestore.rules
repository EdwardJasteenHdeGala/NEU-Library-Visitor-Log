rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Fast-path check for the bootstrap super admin via email token.
     */
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'edwardjasteen.degala@neu.edu.ph';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data;
    }

    function isAnyAdmin() {
      return isBootstrapAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid)) && 
        (getUserData().role == 'admin' || getUserData().isSuperAdmin == true)
      );
    }

    // --- Collection Rules ---

    match /user_profiles/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow list: if isAnyAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAnyAdmin());
      allow delete: if isAnyAdmin();
    }

    match /visits/{visitId} {
      /**
       * Registry Access:
       * We allow all signed-in users to list the collection.
       * This is required for real-time occupancy stats and personal history tracking.
       */
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /feedback/{feedbackId} {
      allow list: if isAnyAdmin();
      allow get: if isSignedIn() && (isAnyAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAnyAdmin();
    }

    match /library_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAnyAdmin();
    }
  }
}