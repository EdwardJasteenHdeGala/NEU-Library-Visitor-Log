
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Tiered admin check: Hardcoded emails + Firestore marker
      let adminEmails = [
        "edwardjasteen.degala@neu.edu.ph",
        "jcesperanza@neu.edu.ph",
        "nhica.valderas@neu.edu.ph"
      ];
      return isSignedIn() && (
        request.auth.token.email in adminEmails || 
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isNotBlocked() {
      return isSignedIn() && !exists(/databases/$(database)/documents/blocked_users/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collections ---

    // USERS: Institutional profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ADMIN ROLES: Marker collection for DBAC
    match /roles_admin/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // BLOCKED USERS: Security blacklist
    match /blocked_users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // VISITS: Library access logs
    match /visits/{visitId} {
      // Allow read for admins (all) or unblocked owners (own)
      allow read: if isSignedIn() && (
        isAdmin() || 
        (isNotBlocked() && (resource == null || resource.data.userId == request.auth.uid))
      );
      allow create: if isSignedIn() && isNotBlocked();
      allow update, delete: if isAdmin();
    }

    // CONFIG: Global operational status
    match /library_config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // NOTIFICATIONS: User alerts
    match /notifications/{notificationId} {
      // Allow read for admins (all) or owners (own)
      allow read: if isSignedIn() && (
        isAdmin() || 
        (resource == null || resource.data.userId == request.auth.uid)
      );
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() || 
        (resource != null && resource.data.userId == request.auth.uid)
      );
      allow delete: if isAdmin();
    }

    // FEEDBACK: Institutional sentiments
    match /feedback/{feedbackId} {
      allow read: if isSignedIn() || isAdmin(); 
      allow create: if isSignedIn() && isNotBlocked();
      allow update, delete: if isAdmin();
    }

    // AUDIT: Admin action trail
    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
    
    // Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
