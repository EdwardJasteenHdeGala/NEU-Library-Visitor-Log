rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && (
        // Explicit whitelist for immediate authorization via token email
        request.auth.token.email.lower() == 'edwardjasteen.degala@neu.edu.ph' ||
        request.auth.token.email.lower() == 'jcesperanza@neu.edu.ph' ||
        request.auth.token.email.lower() == 'nhica.valderas@neu.edu.ph' ||
        // Dynamic role check for other synchronized administrators
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == 'admin')
      );
    }

    function isMember() {
      return isSignedIn() && (
        request.auth.token.email.lower().endsWith('@neu.edu.ph') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserData().role == 'user')
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /visits/{visitId} {
      // Admins see all. Users see only their own.
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      // Listing is allowed for admins only for aggregated statistics.
      allow list: if isAdmin(); 
      // Only members (non-guests) can log visits.
      allow create: if isMember() || isAdmin();
      allow update, delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /invites/{inviteId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == resource.data.email.lower());
      allow write: if isAdmin();
    }
    
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
